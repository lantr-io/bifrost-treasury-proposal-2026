# Network: preprod, preview, or mainnet. Picks the right params/*.ts and
# Blockfrost endpoint. Mainnet stays out of params/select.ts dispatch — wire
# params/mainnet.ts in explicitly when you're ready to submit there.
NETWORK=preprod

# Blockfrost project id for the target network. IDs are network-scoped
# (preprod_*, preview_*, mainnet_*); the URL prefix MUST match. Free tier
# works for any testnet. Get one from https://blockfrost.io.
BLOCKFROST_PROJECT_ID=preprod_REPLACE_ME
